<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Tema claro principal de TaskMaster.
        Hereda de Material3 DayNight para compatibilidad.
    -->
    <style name="Theme.TaskMaster" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Colores primarios -->
        <item name="colorPrimary">@color/tm_primary</item>
        <item name="colorPrimaryDark">@color/tm_primary_dark</item>
        <item name="colorAccent">@color/tm_accent</item>

        <!-- Toolbar -->
        <item name="actionBarStyle">@style/TaskMasterToolbar</item>

        <!-- Fondo de la ventana -->
        <item name="android:windowBackground">@color/surface_light</item>

        <!-- StatusBar -->
        <item name="android:statusBarColor">@color/tm_primary_dark</item>
        <item name="android:navigationBarColor">@color/surface_light</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
    </style>

    <!--
        Tema oscuro de TaskMaster.
        Se aplica desde MainActivity cuando el usuario activa el modo oscuro.
    -->
    <style name="Theme.TaskMaster.Dark" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/tm_primary_light</item>
        <item name="colorPrimaryDark">@color/tm_primary</item>
        <item name="colorAccent">@color/tm_accent</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>
    </style>

    <!-- Estilo de la Toolbar -->
    <style name="TaskMasterToolbar" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/tm_primary</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <!-- Shapes redondeadas -->
    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Tema para la splash screen / launcher -->
    <style name="Theme.TaskMaster.Launcher" parent="Theme.TaskMaster">
        <item name="android:windowBackground">@color/tm_primary</item>
    </style>

</resources>
